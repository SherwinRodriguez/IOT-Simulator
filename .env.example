# ─── Zoho OAuth 2.0 Credentials ───────────────────────────────────
# Register at: https://api-console.zoho.in (or your region's console)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_DEFAULT_REGION=in

# ─── Encryption (AES-256 key — MUST be exactly 32 characters) ────
ENCRYPTION_SECRET=

# ─── Database ─────────────────────────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_URL=

# ─── MQTT ─────────────────────────────────────────────────────────
# Format: tcp://<hub>:<port>  or  ssl://<hub>:<port>
MQTT_BROKER=

# ─── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ─── Frontend (for Docker build) ─────────────────────────────────
# Leave empty to use relative URLs (recommended when behind Nginx)
VITE_API_BASE_URL=
